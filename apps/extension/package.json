{
  "name": "@resume-forge/extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "ResumeForge Chrome extension (Manifest V3). Reuses @resume-forge/core.",
  "scripts": {
    "dev": "vite build --watch",
    "build": "npm run typecheck && vite build && vite build --config vite.content.config.ts",
    "build:main": "vite build",
    "build:content": "vite build --config vite.content.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@resume-forge/core": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "0.0.278",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^24.1.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^2.1.9"
  }
}
