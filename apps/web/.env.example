# Supabase connection — the operator supplies their own Supabase project.
# These MUST be provided via environment; never hard-code credentials in source.
# The anon key is safe for the browser (RLS protects data); do NOT put the
# service_role/secret key here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# NOTE: Users do NOT bring their own API key. All AI calls are routed through
# the `ai-proxy` Supabase Edge Function, which holds a single Google Gemini
# FREE-TIER key as a SERVER-SIDE SECRET. The Gemini key is NEVER shipped to the
# browser and must NOT be placed in any VITE_* variable.
#
# Get a free Gemini key (no credit card): https://aistudio.google.com/apikey
# Set the key as an edge-function secret (operator step, run once):
#   supabase secrets set GEMINI_API_KEY=your_key
# Deploy the function (use --no-verify-jwt to allow logged-out users):
#   supabase functions deploy ai-proxy
# See supabase/functions/ai-proxy/README.md for full details.

# Optional: override the proxy endpoint. Defaults to
# ${VITE_SUPABASE_URL}/functions/v1/ai-proxy when unset.
# VITE_AI_PROXY_URL=https://your-project-ref.functions.supabase.co/functions/v1/ai-proxy
